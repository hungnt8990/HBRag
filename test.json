{
  "chunk_mode": "recursive",
  "chunk_size": 1000,
  "chunk_overlap": 150,
  "top_k": 5,
  "candidate_k": 20,
  "answer_mode": "hybrid",
  "answer_style": "detailed",
  "max_context_chars": 6000,
  "heading_rules": [
    {
      "name": "roman_heading",
      "level": 1,
      "pattern": "^[ \\t]*(?P<label>)(?P<number>[IVXLCDM]+)[\\.\\)]\\s+(?P<title>.+)$",
      "metadata_key": "section_title",
      "number_metadata_key": "section_number",
      "boundary": true,
      "enabled": true
    },
    {
      "name": "numbered_heading",
      "level": 2,
      "pattern": "^[ \\t]*(?P<label>)(?P<number>\\d+(?:\\.\\d+)*)[\\.\\)]\\s+(?P<title>.+)$",
      "metadata_key": "subsection_title",
      "number_metadata_key": "subsection_number",
      "boundary": true,
      "enabled": true
    }
  ]
}