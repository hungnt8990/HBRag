# -----------------------------------------------------------------------------
# Application / API
# Core app metadata and browser origins allowed to call the backend.
# -----------------------------------------------------------------------------
APP_NAME=HBRag API
APP_VERSION=0.1.0
ENVIRONMENT=local
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOWED_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):[0-9]+

# -----------------------------------------------------------------------------
# Local ports / frontend API URL
# Used by local Docker/dev scripts and the Next.js frontend.
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# PostgreSQL
# Main relational database for documents, chunks, users, logs, and RAG profiles.
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hbrag
POSTGRES_PASSWORD=hbrag_password
POSTGRES_DB=hbrag
DATABASE_URL=postgresql+asyncpg://hbrag:hbrag_password@localhost:5432/hbrag
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Qdrant vector store
# Dense/sparse vector collection settings used for retrieval.
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
# Versioned collection for BGE-M3 1024-dim dense vector + named sparse vector.
# Keep AUTO_RECREATE_COLLECTION=false so an old incompatible collection is not deleted silently.
QDRANT_COLLECTION_NAME=hbrag_chunks_bge_m3_1024_sparse_v1
QDRANT_UPSERT_BATCH_SIZE=128
AUTO_RECREATE_COLLECTION=false

# -----------------------------------------------------------------------------
# Chunking defaults
# Baseline chunk size/overlap when no RAG profile override is selected.
# -----------------------------------------------------------------------------
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=150

# -----------------------------------------------------------------------------
# Memory / Mem0
# Conversation memory behavior and optional Mem0 integration.
# -----------------------------------------------------------------------------
MEMORY_PROVIDER=hybrid
MEMORY_ENABLED=true
MEM0_ENABLED=true
MEM0_API_KEY=
MEM0_MODE=oss
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_USER_PREFIX=hbrag
MEMORY_TOP_K=5
MEMORY_AUTO_SAVE=true
MEMORY_INJECT_INTO_PROMPT=true
SESSION_SUMMARY_EVERY_N_MESSAGES=10

# -----------------------------------------------------------------------------
# Embedding model
# Provider and model for dense embeddings used by vector indexing/search.
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://vllm02.cpc.vn/v1
EMBEDDING_API_KEY=your_key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# -----------------------------------------------------------------------------
# Reranker model
# Optional reranker used after hybrid/vector retrieval and before answer generation.
# -----------------------------------------------------------------------------
RERANKER_PROVIDER=openai_compatible
RERANKER_BASE_URL=https://vllm02.cpc.vn/v1
RERANKER_API_KEY=your_key
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_ENDPOINT_PATH=/rerank

# -----------------------------------------------------------------------------
# Answer-generation LLM
# Default LLM used for chat/answer generation and as fallback for enrichment.
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://vllm02.cpc.vn/v1
LLM_API_KEY=your_key
LLM_MODEL=Qwen/Qwen3.5-9B

# -----------------------------------------------------------------------------
# Chunk enrichment LLM
# Runtime LLM config for parse -> chunk -> enrich -> index.
# RAG profiles/Postgres do not store enrichment config; toggles/provider/URL/model live here.
# CHUNK_ENRICHMENT_MODE: off, metadata_only, selective, all.
# selective writes rule_enrichment for every chunk but calls LLM only for useful chunks.
# ENRICHMENT_FORCE_ON_REINGEST=false keeps hash cache active during reingest.
# USE_ENRICHED_CONTENT_FOR_EMBEDDING controls whether indexing appends LLM enrichment.
# EMBEDDING_* controls normal ingest enrich; REINGEST_* overrides refresh/reingest.
# Empty embedding/reingest values fall back to CHUNK_ENRICHMENT_* and then LLM_*.
# -----------------------------------------------------------------------------
CHUNK_ENRICHMENT_ENABLED=true
CHUNK_ENRICHMENT_MODE=selective
CHUNK_ENRICHMENT_MIN_CHARS=300
# CHUNK_ENRICHMENT_MAX_LLM_CHUNKS_PER_DOCUMENT=200
CHUNK_ENRICHMENT_CONCURRENCY=2
CHUNK_ENRICHMENT_PROMPT_VERSION=v2
USE_ENRICHED_CONTENT_FOR_EMBEDDING=true
RETRIEVAL_ENRICHMENT_ENABLED=true
ENRICHMENT_FORCE_ON_REINGEST=false
ENRICHMENT_UPDATE_KEYWORD_SEARCH_VECTOR=true
CHUNK_ENRICHMENT_PROVIDER=openai_compatible
CHUNK_ENRICHMENT_BASE_URL=https://vllm02.cpc.vn/v1
CHUNK_ENRICHMENT_MODEL=Qwen/Qwen3.5-9B
CHUNK_ENRICHMENT_MAX_CHARS=6000
CHUNK_ENRICHMENT_VERSION=v1
EMBEDDING_ENRICHMENT_PROVIDER=openai_compatible
EMBEDDING_ENRICHMENT_BASE_URL=https://vllm02.cpc.vn/v1
EMBEDDING_ENRICHMENT_MODEL=Qwen/Qwen3.5-9B
EMBEDDING_ENRICHMENT_MAX_CHARS=6000
EMBEDDING_ENRICHMENT_VERSION=v1
REINGEST_ENRICHMENT_PROVIDER=openai_compatible
REINGEST_ENRICHMENT_BASE_URL=https://vllm02.cpc.vn/v1
REINGEST_ENRICHMENT_MODEL=Qwen/Qwen3.5-9B
REINGEST_ENRICHMENT_MAX_CHARS=6000
REINGEST_ENRICHMENT_VERSION=v1

# -----------------------------------------------------------------------------
# Document-aware RAG / adaptive retrieval
# Generic switches based on document structure and query shape, not on a domain.
# ENABLE_OFFLINE_ENRICHMENT gates parse -> chunk -> enrich -> index enrichment.
# ENABLE_QUERY_ENRICHMENT expands search terms at ask time without creating facts.
# ENABLE_CONTEXT_EXPANSION pulls neighboring/section/table/summary evidence.
# Completeness and second retrieval are adaptive safeguards; keep disabled until
# a separate verification pass is wired for production latency/cost.
# *_TOP_K values only widen retrieval windows when greater than the request/profile.
# MAX_CONTEXT_CHARS is an upper budget for overview/count/table context expansion.
# -----------------------------------------------------------------------------
ENABLE_OFFLINE_ENRICHMENT=true
ENABLE_QUERY_ENRICHMENT=true
ENABLE_CONTEXT_EXPANSION=true
ENABLE_COMPLETENESS_CHECK=false
ENABLE_SECOND_RETRIEVAL=false
MAX_SECOND_RETRIEVAL_ROUNDS=1
OVERVIEW_TOP_K=12
RAW_TOP_K=0
SUMMARY_TOP_K=6
TABLE_TOP_K=10
MAX_CONTEXT_CHARS=20000

# -----------------------------------------------------------------------------
# GraphRAG / Neo4j
# Graph indexing, extraction, merge, and retrieval expansion settings.
# -----------------------------------------------------------------------------
GRAPH_ENABLED=false
GRAPH_PROVIDER=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=hbrag_password

GRAPH_ENTITY_EXTRACTION_ENABLED=true
GRAPH_RELATION_EXTRACTION_ENABLED=true
GRAPH_EXPANSION_ENABLED=true

GRAPH_MAX_ENTITIES_PER_CHUNK=30
GRAPH_MAX_RELATIONS_PER_CHUNK=40
GRAPH_EXPANSION_DEPTH=1
GRAPH_EXPANSION_LIMIT=20
GRAPH_MIN_ENTITY_CONFIDENCE=0.4
GRAPH_MIN_RELATION_CONFIDENCE=0.4
GRAPH_EXTRACTOR_PROVIDER=llm
GRAPH_ENTITY_MERGE_ENABLED=true
GRAPH_RELATION_MERGE_ENABLED=true

# -----------------------------------------------------------------------------
# MinIO object storage
# Document file storage and local MinIO console/API settings.
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9100
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=hbrag-documents
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# Authentication
# JWT signing and access token lifetime.
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
