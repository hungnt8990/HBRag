# -----------------------------------------------------------------------------
# Application / API
# Core app metadata and browser origins allowed to call the backend.
# -----------------------------------------------------------------------------
APP_NAME=HBRag API
APP_VERSION=0.1.0
ENVIRONMENT=local
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOWED_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):[0-9]+

# -----------------------------------------------------------------------------
# Local ports / frontend API URL
# Used by local Docker/dev scripts and the Next.js frontend.
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# PostgreSQL
# Main relational database for documents, chunks, users, logs, and RAG profiles.
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hbrag
POSTGRES_PASSWORD=hbrag_password
POSTGRES_DB=hbrag
DATABASE_URL=postgresql+asyncpg://hbrag:hbrag_password@localhost:5432/hbrag
DATABASE_ECHO=false

# -----------------------------------------------------------------------------
# Qdrant vector store
# Dense/sparse vector collection settings used for retrieval.
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=hbrag_chunks
QDRANT_UPSERT_BATCH_SIZE=128
AUTO_RECREATE_COLLECTION=false

# -----------------------------------------------------------------------------
# Chunking defaults
# Baseline chunk size/overlap when no RAG profile override is selected.
# -----------------------------------------------------------------------------
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=150

# -----------------------------------------------------------------------------
# Memory / Mem0
# Conversation memory behavior and optional Mem0 integration.
# -----------------------------------------------------------------------------
MEMORY_PROVIDER=local
MEMORY_ENABLED=true
MEM0_ENABLED=false
MEM0_API_KEY=
MEM0_MODE=oss
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_USER_PREFIX=hbrag
MEMORY_TOP_K=5
MEMORY_AUTO_SAVE=true
MEMORY_INJECT_INTO_PROMPT=true
SESSION_SUMMARY_EVERY_N_MESSAGES=10

# -----------------------------------------------------------------------------
# Embedding model
# Provider and model for dense embeddings used by vector indexing/search.
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=fake
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=384

# -----------------------------------------------------------------------------
# Reranker model
# Optional reranker used after hybrid/vector retrieval and before answer generation.
# -----------------------------------------------------------------------------
RERANKER_PROVIDER=fake
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=
RERANKER_ENDPOINT_PATH=/rerank

# -----------------------------------------------------------------------------
# Answer-generation LLM
# Default LLM used for chat/answer generation and as fallback for enrichment.
# -----------------------------------------------------------------------------
LLM_PROVIDER=fake
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# -----------------------------------------------------------------------------
# Chunk enrichment LLM
# Runtime LLM config for parse -> chunk -> enrich -> index.
# RAG profiles/Postgres do not store enrichment config; toggles/provider/URL/model live here.
# EMBEDDING_* controls normal ingest enrich; REINGEST_* overrides refresh/reingest.
# Empty provider/model values fall back to CHUNK_ENRICHMENT_* and then LLM_*.
# -----------------------------------------------------------------------------
CHUNK_ENRICHMENT_ENABLED=false
RETRIEVAL_ENRICHMENT_ENABLED=false
ENRICHMENT_FORCE_ON_REINGEST=true
ENRICHMENT_UPDATE_KEYWORD_SEARCH_VECTOR=true
CHUNK_ENRICHMENT_PROVIDER=
CHUNK_ENRICHMENT_BASE_URL=
CHUNK_ENRICHMENT_MODEL=
CHUNK_ENRICHMENT_MAX_CHARS=6000
CHUNK_ENRICHMENT_VERSION=v1
EMBEDDING_ENRICHMENT_PROVIDER=
EMBEDDING_ENRICHMENT_BASE_URL=
EMBEDDING_ENRICHMENT_MODEL=
EMBEDDING_ENRICHMENT_MAX_CHARS=6000
EMBEDDING_ENRICHMENT_VERSION=v1
REINGEST_ENRICHMENT_PROVIDER=
REINGEST_ENRICHMENT_BASE_URL=
REINGEST_ENRICHMENT_MODEL=
REINGEST_ENRICHMENT_MAX_CHARS=6000
REINGEST_ENRICHMENT_VERSION=v1

# -----------------------------------------------------------------------------
# GraphRAG / Neo4j
# Graph indexing, extraction, merge, and retrieval expansion settings.
# -----------------------------------------------------------------------------
GRAPH_ENABLED=false
GRAPH_PROVIDER=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=hbrag_password

GRAPH_ENTITY_EXTRACTION_ENABLED=true
GRAPH_RELATION_EXTRACTION_ENABLED=true
GRAPH_EXPANSION_ENABLED=true

GRAPH_MAX_ENTITIES_PER_CHUNK=30
GRAPH_MAX_RELATIONS_PER_CHUNK=40
GRAPH_EXPANSION_DEPTH=1
GRAPH_EXPANSION_LIMIT=20
GRAPH_MIN_ENTITY_CONFIDENCE=0.4
GRAPH_MIN_RELATION_CONFIDENCE=0.4
GRAPH_EXTRACTOR_PROVIDER=llm
GRAPH_ENTITY_MERGE_ENABLED=true
GRAPH_RELATION_MERGE_ENABLED=true

# -----------------------------------------------------------------------------
# MinIO object storage
# Document file storage and local MinIO console/API settings.
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=hbrag-documents
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# Authentication
# JWT signing and access token lifetime.
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
