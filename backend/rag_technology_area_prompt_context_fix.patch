+        )
+        wants_goal = "muc tieu" in normalized_query
+
+        def score(context_chunk: ContextChunk) -> tuple[int, int, int, int]:
+            chunk = context_chunk.chunk
+            metadata = chunk.chunk_metadata or {}
+            chunk_type = str(metadata.get("chunk_type") or "")
+            haystack_parts = [chunk.content or ""]
+            for field_name in (
+                "area",
+                "title",
+                "section_title",
+                "heading_path",
+                "table_title",
+                "document_title",
+            ):
+                value = metadata.get(field_name)
+                if isinstance(value, list):
+                    haystack_parts.extend(str(item) for item in value)
+                elif value is not None:
+                    haystack_parts.append(str(value))
+            haystack = normalize_metadata_value(
+                RagAnswerService._strip_vietnamese_accents(" ".join(haystack_parts))
+            )
+            objective_hit = any(
+                term in haystack
+                for term in (
+                    "muc tieu",
+                    "cong nghe",
+                    "tinh nang",
+                    "quan tri",
+                    "do trung lap",
+                    "cong viec lien quan",
+                )
+            )
