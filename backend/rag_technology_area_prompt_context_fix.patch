+def test_technology_area_goal_prompt_keeps_narrative_context_with_table_row() -> None:
+    from uuid import uuid4
+
+    document_id = uuid4()
+    table_row = SimpleNamespace(
+        id=uuid4(),
+        document_id=document_id,
+        chunk_index=3,
+        content=(
+            "TABLE_ROW table_id=tbl row=3 | Mảng công nghệ: Xây dựng nền tảng "
+            "RAG trên dữ liệu nội bộ | Phòng chủ trì: PTUD | Nhân sự đề xuất: "
+            "Nguyễn Quang Lâm"
+        ),
+        chunk_metadata={
+            "chunk_type": "table_row",
+            "area": "Xây dựng nền tảng RAG trên dữ liệu nội bộ",
+        },
+    )
+    objective = SimpleNamespace(
+        id=uuid4(),
+        document_id=document_id,
+        chunk_index=4,
+        content=(
+            "3. Xây dựng nền tảng RAG trên dữ liệu nội bộ\n"
+            "Mục tiêu: khai thác tri thức nội bộ thông qua hệ thống hỏi-đáp "
+            "có dẫn nguồn, chính xác và được phân quyền.\n"
+            "Công nghệ: Advanced RAG, hybrid retrieval, reranking, query rewriting, GraphRAG.\n"
+            "Tính năng: kết hợp tìm kiếm từ khóa + ngữ nghĩa, trích dẫn nguồn."
+        ),
+        chunk_metadata={
+            "chunk_type": "text",
+            "section_title": "Xây dựng nền tảng RAG trên dữ liệu nội bộ",
+        },
+    )
+
+    prompt = RagAnswerService._build_user_prompt(
+        query="Mảng công nghệ RAG trên dữ liệu nội bộ có mục tiêu gì?",
+        context_chunks=[
+            ContextChunk(citation_index=1, chunk=table_row),
+            ContextChunk(citation_index=2, chunk=objective),
+        ],
+    )
+
+    assert "Retrieved Technology Area Context" in prompt
+    assert "ENTITY_MATCHED_ROWS" not in prompt
+    assert prompt.index("Mục tiêu: khai thác tri thức nội bộ") < prompt.index("TABLE_ROW table_id")
