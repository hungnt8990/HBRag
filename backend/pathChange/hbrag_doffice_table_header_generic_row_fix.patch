+def normalize_table_header_and_rows(matrix: list[list[str]], header_flags: list[list[bool]]) -> tuple[list[str], list[list[str]]]:
+    """Return clean headers and only real data rows from an expanded HTML table.
+
+    DOffice/PDF tables often encode multi-line headers as several ordinary ``td``
+    rows instead of a proper ``thead``. For example, the header
+    "Thời gian thực hiện gói thầu (*)" may appear as rows containing only
+    "hiện", "gói", "thầu", "(*)". Those rows must be merged into headers,
+    not embedded and indexed as table_row chunks.
+    """
+    if not matrix:
+        return [], []
+
+    has_header = bool(any(header_flags[0]) or len(matrix) > 1)
+    if not has_header:
+        return [], [[clean_inline_text(value) for value in row] for row in matrix]
+
+    base_headers = [clean_table_header_text(value) for value in matrix[0]]
+    normalized_base = [_normalize_key(header) for header in base_headers]
+    raw_rows = [[clean_inline_text(value) for value in row] for row in matrix[1:]]
+
+    continuation_rows: list[list[str]] = []
+    data_rows: list[list[str]] = []
+    stt_table = bool(normalized_base and normalized_base[0] in {"stt", "tt"})
+    for row in raw_rows:
+        row = [clean_inline_text(value) for value in row]
+        if stt_table:
+            number_index = _find_stt_value_index(row)
+            if number_index is None:
+                continuation_rows.append(row)
+                continue
+            if number_index > 0:
+                row = row[number_index:]
+        data_rows.append(row)
+
+    headers = merge_header_continuations(base_headers, continuation_rows)
+    headers = [header for header in headers if clean_inline_text(header)]
+    normalized_rows = [_fit_row_to_headers(row, len(headers)) for row in data_rows]
+    return headers, normalized_rows
+
+
+def clean_table_header_text(value: str) -> str:
+    text = clean_inline_text(value)
+    text = re.sub(r"\s+-\s+", " ", text)
+    text = re.sub(r"\s+", " ", text).strip(" :;-|")
+    if _normalize_key(text) in {"stt", "tt"}:
+        return "STT"
+    return text
+
+
+def merge_header_continuations(headers: list[str], continuation_rows: list[list[str]]) -> list[str]:
+    merged = [clean_table_header_text(header) for header in headers]
+    previous_targets: list[int] | None = None
+    for row in continuation_rows:
+        values = [clean_table_header_text(value) for value in row if clean_table_header_text(value)]
+        if not values:
+            continue
+        targets = _continuation_target_columns(merged, len(values), previous_targets=previous_targets)
+        if not targets:
+            continue
+        for index, value in zip(targets, values, strict=False):
+            if index >= len(merged):
+                continue
+            current = merged[index]
+            if not current:
+                merged[index] = value
+                continue
+            current_key = _normalize_key(current)
+            value_key = _normalize_key(value)
+            if value not in current and (not value_key or value_key not in current_key.split("_")):
+                merged[index] = clean_table_header_text(f"{current} {value}")
+        previous_targets = targets
+    return [clean_table_header_text(header) for header in merged]
+
+
+def _continuation_target_columns(headers: list[str], value_count: int, *, previous_targets: list[int] | None) -> list[int] | None:
+    if value_count <= 0:
+        return None
+    if previous_targets and len(previous_targets) == value_count:
+        return previous_targets
+
+    normalized = [_normalize_key(header) for header in headers]
+    duplicate_groups: list[list[int]] = []
+    start = 0
+    while start < len(normalized):
+        if not normalized[start]:
+            start += 1
+            continue
+        end = start + 1
+        while end < len(normalized) and normalized[end] == normalized[start]:
+            end += 1
+        group = list(range(start, end))
+        if len(group) == value_count and len(group) > 1:
+            duplicate_groups.append(group)
+        start = end
+    if duplicate_groups:
+        return duplicate_groups[-1]
+
+    non_empty = [index for index, header in enumerate(headers) if clean_inline_text(header)]
+    if value_count == 1 and non_empty:
+        return [non_empty[-1]]
+    if len(non_empty) >= value_count:
+        return non_empty[-value_count:]
+    return None
+
+
+def _find_stt_value_index(row: list[str]) -> int | None:
+    for index, value in enumerate(row[:4]):
+        clean = clean_inline_text(value)
+        if re.fullmatch(r"\d{1,4}(?:\.\d+)?", clean):
+            return index
+    return None
+
+
+def _looks_like_header_continuation_row(row: list[str], *, width: int, flags: list[bool] | None) -> bool:
+    values = [clean_inline_text(value) for value in row if clean_inline_text(value)]
+    if not values:
+        return True
+    if flags and any(flags):
+        return True
+    if len(values) <= max(2, width // 3) and all(len(value) <= 30 for value in values):
+        return True
+    return False
+
+
+def _fit_row_to_headers(row: list[str], header_count: int) -> list[str]:
+    clean_row = [clean_inline_text(value) for value in row]
+    if len(clean_row) >= header_count:
+        return clean_row[:header_count]
+    return clean_row + [""] * (header_count - len(clean_row))
+
+
