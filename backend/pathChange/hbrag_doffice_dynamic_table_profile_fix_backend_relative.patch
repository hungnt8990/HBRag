+def _extract_schema_rows(matrix: list[list[str]], schema: dict[str, Any]) -> list[list[str]]:
+    fields = [field for field in schema.get("fields") or [] if isinstance(field, dict)]
+    if not fields:
+        return []
+    cells = [clean_inline_text(cell) for row in matrix for cell in row]
+    cells = [cell for cell in cells if cell]
+    try:
+        min_start_fields = max(1, int(schema.get("row_start_min_fields") or 1))
+    except (TypeError, ValueError):
+        min_start_fields = 1
+    min_start_fields = min(min_start_fields, len(fields))
+    try:
+        min_non_empty = max(1, int(schema.get("min_row_non_empty_fields") or min_start_fields))
+    except (TypeError, ValueError):
+        min_non_empty = min_start_fields
+
+    rows: list[list[str]] = []
+    index = 0
+    while index < len(cells):
+        if index + min_start_fields <= len(cells) and all(
+            _field_value_matches(fields[field_index], cells[index + field_index])
+            for field_index in range(min_start_fields)
+        ):
+            row = cells[index : index + len(fields)]
+            if len(row) < len(fields):
+                row.extend([""] * (len(fields) - len(row)))
+            if sum(1 for value in row if _optional_string(value)) >= min_non_empty:
+                rows.append(row)
+            index += max(1, len(fields))
+            continue
+        index += 1
+    return rows
+
+
+def _schema_row_metadata(*, headers: list[str], values: list[str], table_schema: dict[str, Any] | None) -> dict[str, Any] | None:
+    if not table_schema:
+        return None
+    fields = [field for field in table_schema.get("fields") or [] if isinstance(field, dict)]
+    if not fields:
+        return None
+    row_fields: dict[str, str] = {}
+    metadata: dict[str, Any] = {"table_schema": table_schema.get("name"), "row_fields": row_fields}
+    keyed_values: dict[str, str] = {}
+    for index, field in enumerate(fields):
+        label = clean_inline_text(field.get("label") or field.get("key") or "")
+        key = _optional_string(field.get("key"))
+        value = clean_inline_text(values[index]) if index < len(values) else ""
+        if label and value:
+            row_fields[label] = value
+        if key:
+            keyed_values[key] = value
+        metadata_key = _optional_string(field.get("metadata_key"))
+        if metadata_key and value:
+            metadata[metadata_key] = value
+    row_keys = [keyed_values[key] for key in _string_list(table_schema.get("row_key_fields")) if keyed_values.get(key)]
+    if row_keys:
+        metadata["row_keys"] = row_keys
+    if not row_fields:
+        metadata["is_table_marker"] = True
+        metadata["indexable"] = False
+        metadata["embedding_enabled"] = False
+    return metadata
+
+
+def _field_value_matches(field: dict[str, Any], value: str) -> bool:
+    patterns = _string_list(field.get("patterns"))
+    if not patterns:
+        return bool(_optional_string(value))
+    normalized = _normalize_for_config(value)
+    for pattern in patterns:
+        pattern_text = str(pattern or "").strip()
+        if not pattern_text:
+            continue
+        try:
+            if re.search(pattern_text, normalized, flags=re.IGNORECASE):
+                return True
+        except re.error:
+            if _normalize_for_config(pattern_text) in normalized:
+                return True
+    return False
+
+
+def _config_text_rule_matches(rule: dict[str, Any], text: str, *, empty_matches: bool = False) -> bool:
+    has_condition = False
+    contains_all = [_normalize_for_config(item) for item in _string_list(rule.get("contains_all"))]
+    contains_any = [_normalize_for_config(item) for item in _string_list(rule.get("contains_any"))]
+    exclude_any = [_normalize_for_config(item) for item in _string_list(rule.get("exclude_any"))]
+    if contains_all:
+        has_condition = True
+        if not all(item and item in text for item in contains_all):
+            return False
+    if contains_any:
+        has_condition = True
+        if not any(item and item in text for item in contains_any):
+            return False
+    if exclude_any:
+        has_condition = True
+        if any(item and item in text for item in exclude_any):
+            return False
+    return has_condition or empty_matches
+
