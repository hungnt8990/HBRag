+def _match_configured_table_schema(*, matrix: list[list[str]], context: str, config: dict[str, Any]) -> dict[str, Any] | None:
+    normalized_context = _normalize_for_config(context)
+    header_text = _normalize_for_config("\n".join(" | ".join(row) for row in matrix[: min(4, len(matrix))]))
+    full_text = _normalize_for_config("\n".join(" | ".join(row) for row in matrix))
+    for schema in config.get("table_schemas") or []:
+        if not isinstance(schema, dict) or schema.get("enabled") is False:
+            continue
+        match = schema.get("match") if isinstance(schema.get("match"), dict) else {}
+        context_ok = _config_text_rule_matches(
+            {
+                "contains_all": match.get("context_contains_all"),
+                "contains_any": match.get("context_contains_any"),
+                "exclude_any": match.get("context_exclude_any"),
+            },
+            normalized_context,
+            empty_matches=True,
+        )
+        header_ok = _config_text_rule_matches(
+            {
+                "contains_all": match.get("header_contains_all"),
+                "contains_any": match.get("header_contains_any"),
+                "exclude_any": match.get("header_exclude_any"),
+            },
+            header_text,
+            empty_matches=True,
+        )
+        body_ok = _config_text_rule_matches(
+            {
+                "contains_all": match.get("contains_all"),
+                "contains_any": match.get("contains_any"),
+                "exclude_any": match.get("exclude_any"),
+            },
+            full_text,
+            empty_matches=True,
+        )
+        if context_ok and header_ok and body_ok:
+            return schema
+    return None
+
