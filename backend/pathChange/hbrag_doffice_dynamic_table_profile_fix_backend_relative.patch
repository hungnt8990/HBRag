+    change_aliases = [_normalize_for_config(item) for item in _string_list(feature_config.get("change_aliases"))]
+    if not feature_aliases or not change_aliases:
+        return False
+    normalized_headers = [_normalize_for_config(header) for header in headers]
+    has_feature = any(alias and any(alias in header for header in normalized_headers) for alias in feature_aliases)
+    has_change = any(alias and any(alias in header for header in normalized_headers) for alias in change_aliases)
+    return has_feature and has_change
