+def _schema_headers(schema: dict[str, Any]) -> list[str]:
+    return [
+        clean_inline_text(field.get("label") or field.get("key") or "")
+        for field in schema.get("fields") or []
+        if isinstance(field, dict) and clean_inline_text(field.get("label") or field.get("key") or "")
+    ]
+
