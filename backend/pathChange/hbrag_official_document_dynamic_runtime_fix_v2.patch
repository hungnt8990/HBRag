+def _looks_like_header_row(values: list[str]) -> bool:
+    normalized = " ".join(_normalize_key(value) for value in values if value)
+    return any(term in normalized for term in ("stt", "ten_nha_thau", "ma_so_thue", "gia_trung_thau", "thoi_gian_thuc", "ly_do"))
