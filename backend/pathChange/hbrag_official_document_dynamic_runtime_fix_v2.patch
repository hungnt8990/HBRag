+def align_schema_row(values: list[str], schema: dict[str, Any]) -> dict[str, str]:
+    clean = [value for value in (clean_inline_text(v) for v in values) if value]
+    if not clean:
+        return {}
+    fields = [field for field in schema.get("fields") or [] if isinstance(field, dict)]
+    if not fields:
+        return {}
