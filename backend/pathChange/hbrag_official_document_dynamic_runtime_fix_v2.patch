+def _resolve_doffice_profile(raw_source: dict[str, Any]) -> str:
+    sample = "\n".join(
+        str(raw_source.get(key) or "")
+        for key in ("ky_hieu", "trich_yeu", "tom_tat", "noi_ban_hanh", "noi_dung")
+    )
+    detected = detect_profile(
+        sample,
+        filename=str(raw_source.get("ten_file") or "DOffice document"),
+        content_type="text/html",
+    )
+    if _profile_has_document_normalizer(detected):
+        return detected
+    for name, config in get_profile_configs().items():
+        if _config_has_document_normalizer(config):
+            return name
+    return detected or "general"
+
+
+def _profile_has_document_normalizer(profile: str | None) -> bool:
+    return _config_has_document_normalizer(get_profile_config(profile))
+
+
+def _config_has_document_normalizer(config: dict[str, Any]) -> bool:
+    return any(isinstance(config.get(key), dict) for key in ("official_document_normalizer", "document_structure_normalizer", "doffice_normalizer"))
+
+
+def _normalizer_disables_enrichment(config: dict[str, Any]) -> bool:
+    for key in ("official_document_normalizer", "document_structure_normalizer", "doffice_normalizer"):
+        value = config.get(key)
+        if isinstance(value, dict) and bool(value.get("disable_llm_enrichment")):
+            return True
+    return False
+
