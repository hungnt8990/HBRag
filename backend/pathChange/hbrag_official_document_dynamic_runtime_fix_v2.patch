+            break
+    row = clean[start:]
+    aligned: dict[str, str] = {}
+    value_index = 0
+    for field in fields:
+        key = str(field.get("key") or "").strip()
+        if not key:
+            continue
+        if value_index >= len(row):
+            break
+        aligned[key] = row[value_index]
+        value_index += 1
+    return aligned
