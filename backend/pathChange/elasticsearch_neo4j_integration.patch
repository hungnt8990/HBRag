+MINERU_FALLBACK_TO_HBRAG=true
+
+ENABLE_EXTERNAL_OCR=true
+EXTERNAL_OCR_URL=https://your-ocr-url
+EXTERNAL_OCR_TIMEOUT_SECONDS=120
+EXTERNAL_OCR_MODE=always
+## Type of EXTERNAL_OCR_MODE
+# never          → không gọi OCR ngoài
