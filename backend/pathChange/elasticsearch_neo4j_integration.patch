+    normalized = re.sub(r"\s+", " ", normalized.casefold()).strip()
+    return normalized
+
+
+def _safe_list(value: Any) -> list[str]:
+    if value is None or value == "":
+        return []
+    if isinstance(value, list | tuple | set):
+        return [str(item) for item in value if str(item).strip()]
