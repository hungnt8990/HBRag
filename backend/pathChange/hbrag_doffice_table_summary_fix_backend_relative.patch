+            "chuc_nang_man_hinh",
+            "chuc_nang_man_hinh_ung_dung",
+            "giao_dien_man_hinh_ung_dung",
+            "giao_dien_man_hinh",
+            "man_hinh",
+            "ten_chuc_nang",
+            "module",
+        }
+        & normalized
+    )
+    has_change_context = bool(
+        {"noi_dung", "noi_dung_hieu_chinh", "hieu_chinh_bo_sung", "mo_ta", "giai_doan", "phase", "nen_tang"}
+        & normalized
+    )
+    return has_feature and has_change_context
+
+
+def _is_procurement_table(headers: list[str]) -> bool:
+    normalized = {_normalize_key(header) for header in headers}
+    return "ten_nha_thau" in normalized or "ma_so_thue" in normalized or any("nha_thau" in header for header in normalized)
+
+
+def _procurement_table_row_metadata(*, headers: list[str], values: list[str]) -> dict[str, Any] | None:
+    if not _is_procurement_table(headers):
+        return None
+    clean_values = [clean_inline_text(value) for value in values]
+    offset = _procurement_row_offset(clean_values)
+    if offset is None:
+        return {"is_table_marker": True, "indexable": False, "embedding_enabled": False}
+
+    is_non_winning = _is_non_winning_procurement_table(headers, clean_values, offset=offset)
+    labels = (
+        ["STT", "Tên nhà thầu", "Mã số thuế", "Lý do nhà thầu không trúng thầu"]
+        if is_non_winning
+        else [
+            "STT",
+            "Tên nhà thầu",
+            "Mã số thuế",
+            "Giá dự thầu (VNĐ)",
+            "Giá dự thầu sau giảm giá (nếu có) (VNĐ)",
+            "Giá trúng thầu (VNĐ)",
+            "Thời gian thực hiện gói thầu",
+            "Thời gian thực hiện hợp đồng",
+            "Nội dung khác (nếu có)",
+        ]
+    )
+    row_values = clean_values[offset : offset + len(labels)]
+    row_fields = {label: value for label, value in zip(labels, row_values, strict=False) if value}
+    vendor_name = row_fields.get("Tên nhà thầu")
+    tax_code = row_fields.get("Mã số thuế")
+    metadata: dict[str, Any] = {
+        "row_number": row_fields.get("STT"),
+        "vendor_name": vendor_name,
+        "contractor_name": vendor_name,
+        "tax_code": tax_code,
+        "feature_name": vendor_name,
+        "row_fields": row_fields,
+        "table_schema": "procurement_non_winning" if is_non_winning else "procurement_winning",
+    }
+    if is_non_winning:
+        metadata["change_content"] = row_fields.get("Lý do nhà thầu không trúng thầu")
+    else:
+        metadata.update(
+            {
+                "bid_price": row_fields.get("Giá dự thầu (VNĐ)"),
+                "bid_price_after_discount": row_fields.get("Giá dự thầu sau giảm giá (nếu có) (VNĐ)"),
+                "winning_price": row_fields.get("Giá trúng thầu (VNĐ)"),
+                "package_execution_time": row_fields.get("Thời gian thực hiện gói thầu"),
+                "contract_execution_time": row_fields.get("Thời gian thực hiện hợp đồng"),
+                "other_content": row_fields.get("Nội dung khác (nếu có)"),
+            }
+        )
+    return metadata
+
+
+def _procurement_row_offset(values: list[str]) -> int | None:
+    for index in range(max(0, len(values) - 2)):
+        if not _looks_like_row_number(values[index]):
+            continue
+        if _looks_like_vendor_name(values[index + 1]) and _looks_like_tax_code(values[index + 2]):
+            return index
+    return None
+
+
+def _is_non_winning_procurement_table(headers: list[str], values: list[str], *, offset: int) -> bool:
+    normalized = {_normalize_key(header) for header in headers}
+    if any("khong_trung_thau" in header or "ly_do" in header for header in normalized):
+        return True
+    tail = [value for value in values[offset + 3 :] if value]
+    return bool(tail) and not any(_looks_like_money(value) or "ngay" in value.casefold() for value in tail)
+
+
+def _looks_like_row_number(value: str | None) -> bool:
+    return bool(re.fullmatch(r"\d{1,4}", str(value or "").strip()))
+
+
+def _looks_like_vendor_name(value: str | None) -> bool:
+    lowered = strip_vietnamese_accents(str(value or "")).casefold()
+    return any(token in lowered for token in ("cong ty", "cty", "tnhh", "co phan", "doanh nghiep", "lien danh"))
+
+
+def _looks_like_tax_code(value: str | None) -> bool:
+    return bool(re.fullmatch(r"\d{10,14}", re.sub(r"\D", "", str(value or ""))))
+
+
+def _looks_like_money(value: str | None) -> bool:
+    clean = str(value or "").strip()
+    return bool(re.fullmatch(r"\d{1,3}(?:[.,]\d{3})+(?:\s*(?:VNĐ|VND|đồng))?", clean, flags=re.IGNORECASE))
+
