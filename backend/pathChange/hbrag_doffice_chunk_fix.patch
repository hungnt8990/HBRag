+def _content_identifiers(content: str) -> list[str]:
+    identifiers: list[str] = []
+    text = str(content or "")
+    for match in IDENTIFIER_PATTERN.finditer(text):
+        token = match.group(0)
+        if _looks_like_content_identifier(token, text, match.start(), match.end()):
+            identifiers.append(token)
+    return _unique_strings(identifiers)
+
+
+def _looks_like_document_code(value: str) -> bool:
+    code = " ".join(str(value or "").split()).strip()
+    if not code:
+        return False
+    if DATE_PATTERN.fullmatch(code) or re.fullmatch(r"\d{1,2}/\d{4}", code):
+        return False
+    if "/" in code:
+        suffix = code.split("/", 1)[1]
+        return any(char.isalpha() for char in suffix)
+    return False
+
+
+def _looks_like_content_identifier(token: str, content: str, start: int, end: int) -> bool:
+    clean = token.strip()
+    if not clean:
+        return False
+    if clean.isdigit():
+        before = content[start - 1] if start > 0 else ""
+        before2 = content[start - 2] if start > 1 else ""
+        after = content[end] if end < len(content) else ""
+        after2 = content[end + 1] if end + 1 < len(content) else ""
+        if before in {".", ","} and before2.isdigit():
+            return False
+        if after in {".", ","} and after2.isdigit():
+            return False
+        if before == "/" or after == "/":
+            return False
+        if len(clean) == 4 and 1900 <= int(clean) <= 2100:
+            return False
+        if len(clean) >= 5:
+            return True
+        prefix = content[max(0, start - 24) : start].casefold()
+        return bool(re.search(r"\b(?:sб»‘|so|mГЈ|ma|id|id_vb)\s*[:#]?\s*$", prefix))
+    if re.fullmatch(r"[A-ZДҗ]+", clean):
+        return False
+    return any(char.isdigit() for char in clean) or "/" in clean
+
