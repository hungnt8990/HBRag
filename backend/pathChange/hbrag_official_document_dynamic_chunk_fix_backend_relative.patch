+def _resolve_doffice_profile(profile: str | None, *, text: str, filename: str | None) -> dict[str, Any]:
+    detection = resolve_profile_with_evidence(
+        profile,
+        text=text,
+        filename=filename,
+        content_type="application/json",
+    )
+    requested = str(profile or "auto").strip().casefold() or "auto"
+    if requested != "auto" or detection.get("profile") != "general":
+        return detection
+    normalizer_profile = _first_profile_with_document_normalizer()
+    if normalizer_profile is None:
+        return detection
+    return {
+        "profile": normalizer_profile,
+        "mode": "source_type_document_normalizer_fallback",
+        "score": max(int(detection.get("score") or 0), 1),
+        "evidence": [
+            *list(detection.get("evidence") or []),
+            {"source": "profile_config", "reason": "document_normalizer_available", "profile": normalizer_profile},
+        ],
+        "candidates": list(detection.get("candidates") or []),
+    }
+
+
+def _first_profile_with_document_normalizer() -> str | None:
+    normalizer_keys = (
+        "official_document_normalizer",
+        "document_structure_normalizer",
+        "doffice_normalizer",
+    )
+    for profile_name, config in get_profile_configs().items():
+        if any(isinstance(config.get(key), dict) for key in normalizer_keys):
+            return profile_name
+    return None
+
+
+def _source_detection_text(source: dict[str, Any]) -> str:
+    parts = [
+        "source_type: doffice_elasticsearch",
+        str(source.get("ky_hieu") or ""),
+        str(source.get("trich_yeu") or ""),
+        str(source.get("noi_ban_hanh") or ""),
+        str(source.get("ten_file") or ""),
+        str(source.get("tom_tat") or ""),
+        str(source.get("noi_dung") or "")[:20000],
+    ]
+    return "\n".join(part for part in parts if part.strip())
+
+
+def _document_profile_value(profile_name: str | None) -> str:
+    clean = "_".join(str(profile_name or "general").strip().split()) or "general"
+    if len(clean) <= 32:
+        return clean
+    return clean[:32]
+
+
 def _duration_ms(started: float) -> int:
     return round((time.perf_counter() - started) * 1000)
